# Copy to .env and fill in to enable the Groq LLM. Without a key the agent runs
# fully offline on its deterministic fallback provider.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional overrides:
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_TIMEOUT=45
# LLM_MAX_RETRIES=3
# MAX_REQUEST_CHARS=4000
